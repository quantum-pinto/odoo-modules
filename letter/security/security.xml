<odoo>
    <!-- Manager Group -->
    <record id="letter_manager_group" model="res.groups">
        <field name="name">Manager</field>
        <field name="category_id" ref="letter.letter_module_category" />
        <!-- Managers inherit permissions from base.group_user -->
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]" />
        <field
            name="users"
            eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"
        />
    </record>

    <!-- Rule for base.group_user: Can only edit their own letters -->
    <record id="letter_user_own_letters_rule" model="ir.rule">
        <field name="name">Letter: User can only edit own letters</field>
        <field name="model_id" ref="model_letter_letter" />
        <field name="domain_force">[('user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]" />
        <field name="perm_read" eval="True" />
        <field name="perm_write" eval="True" />
        <field name="perm_create" eval="True" />
        <field name="perm_unlink" eval="False" />
    </record>

    <!-- Rule for letter_manager_group: Can edit any letter -->
    <record id="letter_manager_all_letters_rule" model="ir.rule">
        <field name="name">Letter: Manager can edit any letter</field>
        <field name="model_id" ref="model_letter_letter" />
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('letter_manager_group'))]" />
        <field name="perm_read" eval="True" />
        <field name="perm_write" eval="True" />
        <field name="perm_create" eval="True" />
        <field name="perm_unlink" eval="True" />
    </record>

    <!-- Rule for base.group_user: Can only view their own inbound letters -->
    <record id="letter_user_own_inbound_letters_rule" model="ir.rule">
        <field name="name">Letter: User can view only own inbound letters</field>
        <field name="model_id" ref="model_letter_inbound" />
        <field name="domain_force">[('user_id', '=', user.partner_id.id)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]" />
        <field name="perm_read" eval="True" />
        <field name="perm_write" eval="False" />
        <field name="perm_create" eval="False" />
        <field name="perm_unlink" eval="False" />
    </record>

    <!-- Rule for letter_manager_group: Can manage all inbound letters -->
    <record id="letter_manager_inbound_letters_rule" model="ir.rule">
        <field name="name">Letter: Manager can manage all inbound letters</field>
        <field name="model_id" ref="model_letter_inbound" />
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('letter_manager_group'))]" />
        <field name="perm_read" eval="True" />
        <field name="perm_write" eval="True" />
        <field name="perm_create" eval="True" />
        <field name="perm_unlink" eval="True" />
    </record>
</odoo>
