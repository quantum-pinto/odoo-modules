<?xml version='1.0' encoding='utf-8' ?>
<odoo>

    <!-- letter_inbound kanban view -->
    <record id="letter_inbound_kanban" model="ir.ui.view">
        <field name="name">letter.inbound.kanban</field>
        <field name="model">letter.inbound</field>
        <field name="arch" type="xml">
            <kanban
                class="o_kanban_dashboard o_letter_kanban o_emphasize_colors"
                sample="1"
            >
                <field name="name" />
                <field name="color" />
                <field name="partner_id" />
                <field name="is_delivered" />
                <field name="description" />
                <field name="status" />
                <field name="is_sender" />
                <templates>
                    <t t-name="kanban-menu" groups="letter.letter_user_group">
                        <div class="container">
                            <div class="o_kanban_card_manage_settings row">
                                <div role="menuitem" aria-haspopup="true" class="col-6">
                                    <ul
                                        class="oe_kanban_colorpicker"
                                        data-field="color"
                                        role="popup"
                                    />
                                </div>
                                <div role="menuitem" class="col-6">
                                    <a
                                        class="dropdown-item"
                                        role="menuitem"
                                        type="edit"
                                    >Manage</a>
                                </div>
                            </div>
                        </div>
                    </t>
                    <t t-name="kanban-box">
                        <div
                            t-attf-class="#{kanban_color(record.color.raw_value)} oe_kanban_global_click o_has_icon oe_kanban_content oe_kanban_card"
                        >
                            <div class="o_project_kanban_main ">
                                <div class="o_kanban_card_content mw-100">
                                    <div class="o_kanban_primary_left">
                                        <div class="o_primary">
                                            <span
                                                class="o_text_overflow"
                                                t-att-title="record.name.value"
                                            >
                                                <t t-esc="record.name.value" />
                                            </span>
                                            <span
                                                class="o_text_overflow"
                                                t-att-title="record.description.value"
                                            >
                                                <t t-esc="record.description.value" />
                                            </span>
                                            <div class="mt-3" invisible="not is_sender">
                                                <span
                                                    class="o_text_overflow"
                                                    t-att-title="record.status.value"
                                                    style="font-weight: bold; text-transform: uppercase;"
                                                >
                                                    <t t-esc="record.status.value" />
                                                </span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="o_kanban_record_bottom mt-3">
                                <div
                                    class="oe_kanban_bottom_left"
                                    invisible="is_delivered or not is_sender"
                                >
                                    <a type="delete" class="btn btn-secondary btn-sm">
                                        <i class="fa fa-trash" />
                                    </a>
                                </div>
                                <div
                                    class="oe_kanban_bottom_left"
                                    t-if="record.is_delivered.raw_value"
                                >
                                    <i class="fa fa-check" style="color: green;" />
                                </div>
                                <div class="oe_kanban_bottom_right">
                                    <field
                                        name="partner_id"
                                        widget="many2one_avatar_user"
                                        t-if="record.partner_id.raw_value"
                                    />
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>



    <!-- letter_inbound tree view -->
    <record id="letter_inbound_tree_view" model="ir.ui.view">
        <field name="name">letter.inbound.tree</field>
        <field name="model">letter.inbound</field>
        <field name="arch" type="xml">
            <tree create="0">
                <field name="company_id" optional="show" />
                <field name="user_id" optional="hide" widget="many2one_avatar_user" />
                <field name="name" />
                <field name="partner_id" widget="many2one_avatar_user" />
                <field name="date" />
                <field name="status" widget="statusbar" statusbar_visible="False" />
            </tree>
        </field>
    </record>


    <!-- letter_inbound form view -->
    <record id="letter_inbound_form_view" model="ir.ui.view">
        <field name="name">letter.inbound.form</field>
        <field name="model">letter.inbound</field>
        <field name="arch" type="xml">
            <form>
               <field name="id" invisible="1" />
               <field name="company_id" invisible="1" />
               <field name="is_delivered" invisible="1" />
               <field name="is_sender" invisible="1" />
               <header>
                    <button
                        name="action_send_inbound_letter"
                        type="object"
                        string="Send"
                        class="btn-primary"
                        invisible="not id or not is_sender or is_delivered"
                    />
                    <button
                        name="action_reply_inbound_letter"
                        type="object"
                        string="Reply"
                        class="btn-primary"
                        invisible="not id or is_sender"
                    />
                </header>
                <sheet>
                    <group>
                        <field name="name" readonly="is_delivered or not is_sender" />
                        <field
                            name="user_id"
                            options="{'no_create': True, 'no_open': True}"
                            widget="many2one_avatar_user"
                            readonly="1"
                            invisible="not is_sender"
                        />
                        <field
                            name="partner_id"
                            options="{'no_create': True, 'no_open': True}"
                            widget="many2one_avatar_user"
                            readonly="is_delivered"
                            invisible="not is_sender"
                        />
                        <field
                            name="partner_id"
                            string="From"
                            options="{'no_create': True, 'no_open': True}"
                            widget="many2one_avatar_user"
                            readonly="1"
                            invisible="is_sender"
                        />
                        <field name="date" readonly="is_delivered or not is_sender" />
                        <field
                            name="description"
                            readonly="is_delivered or not is_sender"
                        />
                        <field
                            name="attachment"
                            widget="binary"
                            readonly="is_delivered or not is_sender"
                        />
                    </group>
                </sheet>
            </form>
        </field>
    </record>



    <!-- letter_inbound_search_view -->
    <record id="letter_inbound_search_view" model="ir.ui.view">
        <field name="name">letter.inbound.search</field>
        <field name="model">letter.inbound</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" />
                <field name="partner_id" />
                <field name="description" />
                <filter
                    string="Archived"
                    name="inactive"
                    domain="[('active', '=', False)]"
                />
                <group expand="1" string="Group By">
                    <filter
                        name="groupby_status"
                        string="status"
                        context="{ 'group_by': 'status' }"
                    />
                </group>
            </search>
        </field>
    </record>



    <!-- letter_inbound action -->
    <record id="letter_inbound_action" model="ir.actions.act_window">
        <field name="name">Inbound Letters</field>
        <field name="res_model">letter.inbound</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No new inbound letters
            </p>
        </field>
    </record>



    <!-- letter_inbound menu -->
    <menuitem
        action="letter_inbound_action"
        id="letter_inbound_menu"
        name="Inbound Letters"
        parent="letters_menu"
        sequence="3"
    />

</odoo>
