<?xml version='1.0' encoding='utf-8' ?>
<odoo>
    <!-- apartmentplug_offer tree view -->
    <record id="apartmentplug_offer_view_tree" model="ir.ui.view">
        <field name="name">apartmentplug.offer.view.tree</field>
        <field name="model">apartmentplug.offer</field>
        <field name="arch" type="xml">
            <tree decoration-success="is_enough" decoration-danger="not is_enough">
                <field name="property_id" optional="hide" />
                <field name="price" />
                <field name="partner_id" />
                <button
                    name="action_accept"
                    string="Accept"
                    type="object"
                    icon="fa-check"
                    class="btn-success"
                />
                <button
                    name="action_refuse"
                    string="Refuse"
                    type="object"
                    icon="fa-times"
                    class="btn-danger"
                />
                <field name="date_created" />
                <field name="status" />
                <field name="is_enough" invisible="1" />
                <field name="property_type_id" invisible="1" />
            </tree>
        </field>
    </record>

    <!-- apartmentplug_offer form view -->
    <record id="apartmentplug_offer_view_form" model="ir.ui.view">
        <field name="name">apartmentplug.offer.view.form</field>
        <field name="model">apartmentplug.offer</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="price" />
                        <field
                            name="partner_id"
                            options="{'no_create': True, 'no_open': True}"
                        />
                        <field name="status" invisible="not id" />
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="apartmentplug_offer_action" model="ir.actions.act_window">
        <field name="name">Offer</field>
        <field name="res_model">apartmentplug.offer</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('property_type_id','=', active_id)]</field>
    </record>
</odoo>
