<?xml version="1.0" encoding="utf-8" ?>
<odoo>

    <record id="apartmentplug_apartment_tree" model="ir.ui.view">
        <field name="name">apartmentplug.apartment.tree</field>
        <field name="model">apartmentplug.apartment</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name" />
                <field name="property_type_id" />
                <field name="user_id" />
                <field name="bedrooms" />
                <field
                    name="tags_ids"
                    widget="many2many_tags"
                    options="{'color_field':'color'}"
                />
                <field name="expected_price" />
                <field name="state" widget="statusbar" statusbar_visible="False" />
                <field name="active" invisible="1" />

            </tree>
        </field>
    </record>

    <record id="apartmentplug_apartment_kanban" model="ir.ui.view">
        <field name="name">apartmentplug.apartment.kanban</field>
        <field name="model">apartmentplug.apartment</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_dashboard o_letter_kanban o_emphasize_colors">
                <field name="name" />
                <field name="property_type_id" />
                <field name="user_id" />
                <field name="expected_price" />
                <field name="state" />
                <field name="active" />
                <field name="color" />
                <templates>
                    <t t-name="kanban-menu" groups="base.group_user">
                        <div class="container">
                            <div class="o_kanban_card_manage_settings row">
                                <div role="menuitem" aria-haspopup="true" class="col-6">
                                    <ul
                                        class="oe_kanban_colorpicker"
                                        data-field="color"
                                        role="popup"
                                    />
                                </div>
                                <div role="menuitem" class="col-6">
                                    <a
                                        class="dropdown-item"
                                        role="menuitem"
                                        type="edit"
                                    >Manage</a>
                                </div>
                            </div>
                        </div>
                    </t>

                    <t t-name="kanban-box">
                        <div
                            t-attf-class="#{kanban_color(record.color.raw_value)} oe_kanban_global_click o_has_icon oe_kanban_content oe_kanban_card"
                        >
                            <div class="o_project_kanban_main ">
                                <div class="o_kanban_card_content mw-100">
                                    <div class="o_kanban_primary_left">
                                        <div class="o_primary">
                                            <div
                                                style="font-weight: bold; font-size: 1.2em; color: #333;"
                                            >
                                                <span
                                                    class="o_text_overflow"
                                                    t-att-title="record.name.value"
                                                >
                                                    <t t-esc="record.name.value" />
                                                </span>
                                            </div>
                                            <div>
                                                <span
                                                    class="o_text_overflow"
                                                    t-att-title="record.expected_price.value"
                                                >
                                                    <t
                                                        t-esc="record.expected_price.value"
                                                    />
                                                </span>
                                            </div>
                                            <div>
                                                <span
                                                    class="o_text_overflow"
                                                    t-att-title="record.property_type_id.value"
                                                >
                                                    <t
                                                        t-esc="record.property_type_id.value"
                                                    />
                                                </span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="o_kanban_record_bottom mt-3">
                                <div class="oe_kanban_bottom_left">
                                    <field
                                        name="state"
                                        widget="statusbar"
                                        statusbar_visible="False"
                                        t-if="record.state.raw_value"
                                    />
                                </div>
                                <div class="oe_kanban_bottom_right">
                                    <field
                                        name="user_id"
                                        widget="many2one_avatar_user"
                                        t-if="record.user_id.raw_value"
                                    />
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>



    <record id="apartmentplug_apartment_form" model="ir.ui.view">
        <field name="name">apartmentplug.apartment.form</field>
        <field name="model">apartmentplug.apartment</field>
        <field name="arch" type="xml">
            <form>
                <field name="active" invisible="1" />
                <field name="color" invisible="1" />
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" class="mb-2" required="1" />
                        </h1>
                    </div>
                    <div>
                       <group>
                            <field
                                name="tags_ids"
                                class="mb-4"
                                widget="many2many_tags"
                                options="{'color_field':'color'}"
                            />
                        </group>
                    </div>

                    <group>
                        <group>
                            <field
                                name="property_type_id"
                                options="{'no_create': True, 'no_open': True}"
                            />
                        </group>
                        <group>
                            <field name="postcode" widget="digital_address" />
                        </group>
                        <group>
                            <field name="date_availability" />
                        </group>
                        <group>
                            <field name="selling_price" />
                        </group>
                        <group>
                            <field name="expected_price" />
                        </group>
                        <group>
                            <field name="best_offer" invisible="not offer_ids" />
                        </group>
                        <group>
                            <field name="color" invisible="1" />
                        </group>
                    </group>
                        <notebook>
                            <page string="Description">
                                    <group>
                                        <field name="description" />
                                    </group>
                                    <group>
                                        <field name="bedrooms" />
                                    </group>
                                    <group>
                                        <field name="living_area" />
                                    </group>
                                    <group>
                                        <field name="facades" />
                                    </group>
                                    <group>
                                        <field name="garage" />
                                    </group>
                                    <group>
                                        <field name="garden" />
                                    </group>
                                    <group>
                                        <field name="garden_area" />
                                    </group>
                                    <group>
                                        <field name="garden_orientation" />
                                    </group>
                                    <group>
                                        <field name="total_area" />
                                    </group>
                            </page>
                             <page string="Offers">
                                    <field name="offer_ids" widget="one2many_list" />
                            </page>
                            <page string="Other Info">
                                <group>
                                    <field
                                    name="user_id"
                                    widget="many2one_avatar_user"
                                    options="{'no_create': True, 'no_open': True}"
                                />
                                </group>
                                <group>
                                    <field
                                    name="partner_id"
                                    widget="many2one_avatar_user"
                                    options="{'no_create': True, 'no_open': True}"
                                />
                                </group>
                            </page>
                        </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="apartmentplug_apartment_action" model="ir.actions.act_window">
        <field name="name">Apartment</field>
        <field name="res_model">apartmentplug.apartment</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No Apartment available. Let's create one!
            </p>
        </field>
    </record>

    <record id="apartmentplug_apartment_search" model="ir.ui.view">
        <field name="name">apartmentplug.apartment.search</field>
        <field name="model">apartmentplug.apartment</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" />
                <filter
                    string="Archived"
                    name="inactive"
                    domain="[('active', '=', False)]"
                />
                <filter
                    string="Low Price"
                    name="groupby_low_price"
                    domain="[('expected_price', '&lt;', 1000)]"
                />

                <filter
                    string="High Price"
                    name="groupby_high_price"
                    domain="[('expected_price', '&gt;', 1000)]"
                />
                <group expand="1" string="Group By">
                    <filter
                        string="State"
                        name="groupby_state"
                        context="{'group_by': 'state'}"
                    />
                    <filter
                        string="Bedrooms"
                        name="groupby_bedrooms"
                        context="{'group_by': 'bedrooms'}"
                    />
                </group>
            </search>
        </field>
    </record>

    <menuitem
        action="apartmentplug_apartment_action"
        id="apartmentplug_apartment_menu"
        name="Apartments"
        parent="apartments_menu"
        sequence="1"
    />
</odoo>
