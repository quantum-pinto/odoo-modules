<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="sign_send_request_view_form_inherit" model="ir.ui.view">
        <field name="name">sign.send.request.view.form.inherit</field>
        <field name="model">sign.send.request</field>
        <field name="inherit_id" ref="sign.sign_send_request_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//group" position="inside">
                <field name="letter_id" invisible="1" />
            </xpath>
             <xpath expr="//form/group/group[1]" position="attributes">
                <attribute name="invisible">letter_id</attribute>
            </xpath>
            <xpath expr="//page[@name='contacts_in_copy']" position="attributes">
                <attribute name="invisible">letter_id</attribute>
            </xpath>
        </field>
    </record>
</odoo>
