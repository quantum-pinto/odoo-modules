<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <record id="view_mac_account_tax_tree" model="ir.ui.view">
        <field name="name">mac.account.tax.tree</field>
        <field name="model">mac.account.tax</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="rate"/>
                <field name="description"/>
            </tree>
        </field>
    </record>

    <record id="view_mac_account_tax_form" model="ir.ui.view">
        <field name="name">mac.account.tax.form</field>
        <field name="model">mac.account.tax</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="rate"/>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_mac_account_tax" model="ir.actions.act_window">
        <field name="name">Mac Account Taxes</field>
        <field name="res_model">mac.account.tax</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_mac_account_tax" name="Pinto Taxes" parent="account.menu_finance_payables" action="action_mac_account_tax" sequence="300"/>

</odoo>
